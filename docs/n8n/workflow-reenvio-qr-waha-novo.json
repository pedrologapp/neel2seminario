    {
      "parameters": {
        "jsCode": "const tel = $('Formatar Telefone').first().json;\nconst checkSem = $('Check Sem 9').first().json;\n\nlet checkCom = null;\ntry {\n  checkCom = $('Check Com 9').first().json;\n} catch {\n  // No 'Check Com 9' nao executou (caminho TRUE do IF). Esperado.\n}\n\nlet chatId = null;\nlet formato = null;\n\nif (checkSem?.numberExists) {\n  chatId = tel.chatIdSemNove;\n  formato = 'sem9';\n} else if (checkCom?.numberExists) {\n  chatId = tel.chatIdComNove;\n  formato = 'com9';\n}\n\nif (!chatId) {\n  throw new Error(`Numero ${tel.raw} nao tem WhatsApp registrado.`);\n}\n\nreturn [{ json: { chatId, formato, phoneRaw: tel.raw } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -700,
        300
      ],
      "id": "cccccccc-cccc-cccc-cccc-cccccccccccc",
      "name": "Resolver chatId"
    },
    {
      "parameters": {
        "jsCode": "const inscricao = $('Buscar Inscricao').first().json;\nconst aluno     = $('Buscar Aluno').first().json;\nconst evento    = $('Buscar Evento').first().json;\nconst phoneWaha = $('Resolver chatId').first().json.chatId;\n\nconst itens = inscricao.itens || [];\nlet total = 0;\nconst linhas = itens\n  .filter(it => (it.qtd || 0) > 0)\n  .map(it => {\n    const q = it.qtd || 0;\n    total += q;\n    return `• ${q > 1 ? q + 'x ' : ''}${(it.nome || 'Senha').trim()}`;\n  })\n  .join('\\n');\n\nconst nomeEvento = (evento.nome || '').trim();\nconst nomeAluno  = (aluno?.nome_completo || inscricao.responsavel_nome || '').trim();\n\nconst texto =\n`🔁 *Reenvio dos seus QR Codes*\n\n  *${nomeEvento}*\n  Aluno(a): ${nomeAluno}\n\n  ✅ ${total} ${total === 1 ? 'senha' : 'senhas'}\n\n A seguir, os QR Codes pra entrada no evento. 💙\n Escola Amadeus`;\n\nreturn [{ json: { texto, phone_waha: phoneWaha } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -500,
        300
      ],
      "id": "dddddddd-dddd-dddd-dddd-dddddddddddd",
      "name": "Montar Texto Reenvio"
    },
    {
      "parameters": {
        "resource": "chatting",
        "operation": "Send Text",
        "session": "=amadeus",
        "chatId": "={{ $json.phone_waha }}",
        "text": "={{ $json.texto }}",
        "requestOptions": {}
      },
      "type": "@devlikeapro/n8n-nodes-waha.WAHA",
      "typeVersion": 202502,
      "position": [
        -300,
        300
      ],
      "id": "eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee",
      "name": "Enviar Texto Reenvio",
      "credentials": {
        "wahaApi": {
          "id": "Wa5n1cK3Gl4WH4bW",
          "name": "WAHA account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const inscricao = $('Buscar Inscricao').first().json;\nconst evento = $('Buscar Evento').first().json;\nconst aluno  = $('Buscar Aluno').first().json;\nconst phoneWaha = $('Resolver chatId').first().json.chatId;\n\nlet tickets = [];\ntry {\n  tickets = $('Buscar Tickets').all().map(i => i.json);\n} catch {\n  // Buscar Tickets sem resultado — esperado em inscrição nova.\n}\n\nif (tickets.length === 0) {\n  // Inscrição sem tickets: gera QRs novos na hora (mesma lógica do fluxo principal)\n  const eventoShort = (evento.slug || 'EVT').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 8);\n  const gerarToken = () => {\n    const ts = Date.now().toString(36).toUpperCase();\n    const rnd = Math.random().toString(36).substring(2, 8).toUpperCase();\n    return 'AMZ-' + eventoShort + '-' + ts + '-' + rnd;\n  };\n\n  const itens = (inscricao.itens || []).filter(it => (it.qtd || 0) > 0);\n  let ordem = 0;\n  for (const item of itens) {\n    for (let i = 0; i < (item.qtd || 0); i++) {\n      ordem++;\n      const token = gerarToken();\n      const dadosQR = (aluno?.nome_completo || inscricao.responsavel_nome || '') + ' | ' + (item.nome || 'Senha') + ' | ' + token;\n      tickets.push({\n        nome_tipo: item.nome || 'Senha',\n        ordem,\n        token,\n        qr_url: 'https://api.qrserver.com/v1/create-qr-code/?size=400x400&format=png&data=' + encodeURIComponent(dadosQR),\n      });\n    }\n  }\n  if (tickets.length === 0) {\n    throw new Error('Inscrição sem itens e sem tickets — nada pra enviar.');\n  }\n}\n\nconst total = tickets.length;\nreturn tickets\n  .sort((a, b) => (a.ordem || 0) - (b.ordem || 0))\n  .map((t, i) => ({ json: {\n    phone_waha:   phoneWaha,\n    qr_url:       t.qr_url,\n    token:        t.token,\n    nome_tipo:    t.nome_tipo,\n    ordem:        t.ordem || i + 1,\n    senha_label:  'Senha ' + (t.ordem || i + 1) + ' de ' + total,\n    evento_nome:  (evento.nome || '').trim(),\n    aluno_nome:   aluno?.nome_completo || inscricao.responsavel_nome || '',\n    aluno_serie:  aluno?.serie || '',\n    evento_data:  evento.data_evento || '',\n    evento_local: evento.local || '',\n  }}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -100,
        300
      ],
      "id": "ffffffff-ffff-ffff-ffff-ffffffffffff",
      "name": "Gerar Items QR"
    },
