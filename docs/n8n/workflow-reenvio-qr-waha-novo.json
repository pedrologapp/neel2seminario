      "parameters": {
        "jsCode": "const d = $input.first().json.body;\nconst inscricaoId = d?.inscricaoId;\nconst isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(inscricaoId || '');\nif (!isUuid) {\n  throw new Error('inscricaoId ausente ou inválido');\n}\nreturn [{ json: { inscricaoId, adminEmail: d?.adminEmail || 'admin' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2200,
        200
