    {
      "parameters": {
        "jsCode": "const inscricao = $('Buscar Inscricao').first().json;\n\nlet d = (inscricao.telefone || '').toString().replace(/\\D/g, '');\nif (d.startsWith('55') && d.length > 11) d = d.substring(2);\n\nlet ddd, num;\nif (d.length <= 9) { ddd = '84'; num = d; }\nelse { ddd = d.substring(0, 2); num = d.substring(2); }\n\nconst numSemNove = (num.length === 9 && num.startsWith('9')) ? num.substring(1) : num;\n\nreturn [{ json: {\n  raw: inscricao.telefone,\n  phoneSemNove: `55${ddd}${numSemNove}`,\n  phoneComNove: `55${ddd}9${numSemNove}`,\n  chatIdSemNove: `55${ddd}${numSemNove}@c.us`,\n  chatIdComNove: `55${ddd}9${numSemNove}@c.us`,\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1500,
        300
      ],
      "id": "88888888-8888-8888-8888-888888888888",
      "name": "Formatar Telefone"
    },
    {
      "parameters": {
        "resource": "chatting",
        "operation": "Check Number Status",
        "session": "=amadeus",
        "phone": "={{ $json.phoneSemNove }}"
      },
      "type": "@devlikeapro/n8n-nodes-waha.WAHA",
      "typeVersion": 202502,
