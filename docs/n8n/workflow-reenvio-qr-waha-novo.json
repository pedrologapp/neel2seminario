        "resource": "chatting",
        "operation": "Send Image",
        "session": "=amadeus",
        "chatId": "={{ $json.phone_waha }}",
        "file": "={\n  \"mimetype\": \"image/png\",\n  \"filename\": \"qrcode.png\",\n  \"url\": \"{{ $json.qr_url }}\"\n}",
        "caption": "=💙 {{ $json.evento_nome }}\n\n  🎟️ Senha: *{{ $json.senha_label }}*\n  👤 Aluno: *{{ $json.aluno_nome }}*{{ $json.aluno_serie ? ' (' + $json.aluno_serie + ')' : '' }}\n  📅 Data: *{{ ($json.evento_data || '').split('-').reverse().join('/') }}*\n  📍 Local: *{{ $json.evento_local }}*\n\n  Apresente este QR Code na entrada do evento. ✨",
        "requestOptions": {}
      },
