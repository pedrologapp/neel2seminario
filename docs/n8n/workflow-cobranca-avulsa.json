    {
      "parameters": {
        "jsCode": "const d = $input.first().json.body;\n\nconst ref = d?.payment?.externalReference || '';\n\n// Só processa cobranças avulsas (prefixo avulsa_).\n// Inscrições de eventos (UUID puro) e financeiro antigo caem fora.\nconst isAvulsa = ref.startsWith('avulsa_');\n\nconst isValid =\n  ['PAYMENT_RECEIVED', 'PAYMENT_CONFIRMED'].includes(d?.event) &&\n  ['RECEIVED', 'CONFIRMED'].includes(d?.payment?.status) &&\n  d?.payment?.value > 0 &&\n  isAvulsa;\n\nlet shouldProcess = true;\nif (d?.payment?.billingType === 'CREDIT_CARD') {\n  const n = d?.payment?.installmentNumber || 1;\n  shouldProcess = n === 1;\n}\n\nif (!isValid || !shouldProcess) {\n  let motivo = 'não é cobrança avulsa';\n  if (isAvulsa && !shouldProcess) motivo = 'parcela > 1';\n  else if (isAvulsa) motivo = 'evento inválido';\n  return [{ json: { skip: true, motivo } }];\n}\n\nreturn [{ json: {\n  skip: false,\n  cobrancaId: ref.substring('avulsa_'.length),\n  asaasPaymentId: d.payment.id,\n  amount: d.payment.value,\n  billingType: d.payment.billingType,\n} }];"
      },
