    {
      "parameters": {
        "jsCode": "const d = $input.first().json.body;\n\nconst isValid =\n  ['PAYMENT_RECEIVED', 'PAYMENT_CONFIRMED'].includes(d?.event) &&\n  ['RECEIVED', 'CONFIRMED'].includes(d?.payment?.status) &&\n  d?.payment?.value > 0;\n\nlet shouldProcess = true;\nif (d?.payment?.billingType === 'CREDIT_CARD') {\n  const n = d?.payment?.installmentNumber || 1;\n  shouldProcess = n === 1;\n}\n\nconst inscricaoId = d?.payment?.externalReference;\n\nif (!isValid || !shouldProcess || !inscricaoId) {\n  return [{ json: { skip: true, motivo: !isValid ? 'evento inválido' : !shouldProcess ? 'parcela > 1' : 'sem inscricaoId' } }];\n}\n\nreturn [{ json: {\n  skip: false,\n  inscricaoId,\n  asaasPaymentId: d.payment.id,\n  amount: d.payment.value,\n  billingType: d.payment.billingType,\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 800],
      "id": "node-w2-02",
      "name": "Notif: Validar"
    },
