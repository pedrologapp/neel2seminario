            { "name": "access_token", "value": "COLOQUE_SUA_API_KEY_ASAAS_AQUI" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"name\": \"{{ $json.parentName }}\",\n  \"cpfCnpj\": \"{{ $json.cpf_clean }}\",\n  \"email\": \"{{ $json.email }}\",\n  \"mobilePhone\": \"{{ $json.phone_clean }}\",\n  \"externalReference\": \"{{ $json.inscricaoId }}\"\n}",
        "options": {}
      },
