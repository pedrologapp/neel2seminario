    {
      "parameters": {
        "jsCode": "const tickets = $('Notif: Gerar Tickets').all().map(i => i.json);\nconst t = tickets[0];\nconst total = tickets.length;\n\nconst lista = tickets\n  .map(x => `• Senha ${x.ordem}: ${x.nome_tipo} (\\`${x.token}\\`)`)\n  .join('\\n');\n\nconst texto = `🎉 *${t._evento_nome}*\\nPagamento confirmado!\\n\\n*Total de senhas:* ${total}\\n${lista}\\n\\nApresente os QR Codes na entrada do evento.\\nObrigado por participar! 💙\\n\\n— Escola Amadeus`;\n\nreturn [{ json: {\n  chatId: t.phone_waha,\n  texto,\n  inscricao_id: t.inscricao_id,\n} }];"
      },
