      "id": "30acb735-66ba-4da2-b1ac-9e029e09f9f5",
      "name": "Notif: Etapa QR ok",
      "executeOnce": true
    },
    {
      "parameters": {
        "jsCode": " const inscricao = $('Notif: Buscar Inscricao').first().json;\n  const evento    = $('Notif: Buscar Evento').first().json;\n  const aluno     = $('Notif: Buscar Aluno').first().json;\n\n  const phoneWaha = $('Notif: Resolver chatId').first().json.chatId;\n\n  // Token único, com prefixo do slug do evento\n  const eventoShort = (evento.slug || 'EVT').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 8);\n  const gerarToken = () => {\n    const ts  = Date.now().toString(36).toUpperCase();\n    const rnd = Math.random().toString(36).substring(2, 8).toUpperCase();\n    return 'AMZ-' + eventoShort + '-' + ts + '-' + rnd;\n  };\n\n  // Loop pelos itens da inscrição (cada item = um tipo com qtd)\n  const itens = (inscricao.itens || []).filter(it => (it.qtd || 0) > 0);\n  const totalIngressos = itens.reduce((s, it) => s + (it.qtd || 0), 0);\n  if (totalIngressos < 1) {\n    throw new Error('Inscrição sem ingressos — nada pra gerar');\n  }\n\n  const tickets = [];\n  let ordem = 0;\n\n  for (const item of itens) {\n    const qtd = item.qtd || 0;\n    for (let i = 1; i <= qtd; i++) {\n      ordem++;\n      const senhaLabel = 'Senha ' + ordem + ' de ' + totalIngressos;\n      const token = gerarToken();\n      const dadosQR = (aluno.nome_completo || '') + ' | ' + item.nome + ' | ' + token;\n      const qrUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=400x400&format=png&data=' + encodeURIComponent(dadosQR);\n      tickets.push({ json: {\n        // --- colunas da tabela tickets ---\n        inscricao_id:     inscricao.id,\n        evento_id:        inscricao.evento_id,\n        tipo_ingresso_id: item.tipo_id || null,\n        nome_tipo:        item.nome || 'Senha',\n        preco_unitario:   Number(item.preco_unitario || 0),\n        ordem,\n        token,\n        qr_url:           qrUrl,\n        status:           'ativo',\n        aluno_nome:       aluno.nome_completo || '',\n        // --- extras pra mensagem / WAHA (não vão pro banco) ---\n        phone_waha:       phoneWaha,\n        evento:           (evento.nome || '').trim(),\n        numero_senha:     ordem,\n        total_senhas:     totalIngressos,\n        senha_label:      senhaLabel,\n        descricao:        item.nome || 'Senha',\n      }});\n    }\n  }\n\n  return tickets;\n"
      },
      "name": "Gerar_Tokens",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1904,
        2080
      ],
      "id": "7cc3318a-76ff-4371-a875-dd5dd1942b7d"
    },
    {
      "parameters": {
        "jsCode": " const inscricao = $('Notif: Buscar Inscricao').first().json;\n  const aluno     = $('Notif: Buscar Aluno').first().json;\n  const evento    = $('Notif: Buscar Evento').first().json;\n\n  const phoneWaha = $('Notif: Resolver chatId').first().json.chatId;\n\n  // Monta as linhas de senhas a partir dos itens da inscrição\n  const itens = inscricao.itens || [];\n  let total = 0;\n  const linhas = itens\n    .filter(it => (it.qtd || 0) > 0)\n    .map(it => {\n      const q = it.qtd || 0;\n      total += q;\n      return `• ${q > 1 ? q + 'x ' : ''}${(it.nome || 'Senha').trim()}`;\n    })\n    .join('\\n');\n\n  const nomeEvento = (evento.nome || '').trim();\n  const nomeAluno  = (aluno.nome_completo || '').trim();\n\n  const texto =\n  `🎉 *Pagamento confirmado!*\n\n    *${nomeEvento}*\n    Aluno(a): ${nomeAluno}\n\n    ✅ ${total} ${total === 1 ? 'senha confirmada' : 'senhas confirmadas'}\n\n\n   Qualquer dúvida, estamos à disposição! 💙\n   Escola Amadeus`;\n\n  return [{ json: { texto, phone_waha: phoneWaha } }];;"
      },
