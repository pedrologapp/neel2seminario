    {
      "parameters": {
        "jsCode": "  const inscricao = $('Notif: Buscar Inscricao').first().json;\n  const evento = $('Notif: Buscar Evento').first().json;\n  const aluno = $('Notif: Buscar Aluno').first().json;\n\n  // Prefixo do token baseado no slug do evento\n  const eventoShort = (evento.slug || 'EVT').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 8);\n  const gerarToken = () => {\n    const ts = Date.now().toString(36).toUpperCase();\n    const rnd = Math.random().toString(36).substring(2, 8).toUpperCase();\n    return `AMZ-${eventoShort}-${ts}-${rnd}`;\n  };\n\n  // Loop pelos itens da inscrição, gera 1 ticket por senha\n  const tickets = [];\n  let ordem = 0;\n  const itens = inscricao.itens || [];\n  for (const item of itens) {\n    const qtd = item.qtd || 1;\n    for (let i = 0; i < qtd; i++) {\n      ordem += 1;\n      const token = gerarToken();\n      tickets.push({\n        inscricao_id: inscricao.id,\n        evento_id: inscricao.evento_id,\n        tipo_ingresso_id: item.tipo_id || null,\n        nome_tipo: item.nome || 'Senha',\n        preco_unitario: Number(item.preco_unitario || 0),\n        ordem,\n        token,\n        qr_url: `https://api.qrserver.com/v1/create-qr-code/?data=${encodeURIComponent(token)}&size=500x500&margin=10`,\n        aluno_nome: aluno?.nome_completo || null,\n        phone_waha: $('Notif: Resolver chatId').first().json.chatId,\n        _evento_nome: evento.nome,\n        _aluno_serie: aluno?.serie || '',\n        _aluno_turma: aluno?.turma || '',\n        _responsavel_nome: inscricao.responsavel_nome,\n      });\n    }\n  }\n\n  if (tickets.length === 0) {\n    throw new Error('Inscrição sem itens — nenhum ticket pra gerar');\n  }\n\n  return tickets.map(t => ({ json: t }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        2080
      ],
      "id": "4ec47ccf-cc38-4bcc-a78d-d9888439c23b",
