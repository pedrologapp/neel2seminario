        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "=\n  {\n    \"inscricaoId\": \"{{ $('Notif: Validar').first().json.inscricaoId }}\",\n    \"etapa\": \"qrcode\",\n    \"sucesso\": true\n  }",
