    {
      "parameters": {
        "jsCode": " const d = $input.first().json.body;\n\n  const inscricaoId = d?.payment?.externalReference;\n\n  // Só processa se o externalReference for um UUID (sistema de eventos).\n  // Pagamentos do financeiro antigo (AMADEUS_FINANCEIRO...) caem fora.\n  const isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i\n    .test(inscricaoId || '');\n\n  const isValid =\n    ['PAYMENT_RECEIVED', 'PAYMENT_CONFIRMED'].includes(d?.event) &&\n    ['RECEIVED', 'CONFIRMED'].includes(d?.payment?.status) &&\n    d?.payment?.value > 0 &&\n    isUuid;\n\n  let shouldProcess = true;\n  if (d?.payment?.billingType === 'CREDIT_CARD') {\n    const n = d?.payment?.installmentNumber || 1;\n    shouldProcess = n === 1;\n  }\n\n  if (!isValid || !shouldProcess || !inscricaoId) {\n    let motivo = 'sem inscricaoId';\n    if (inscricaoId && !isUuid) motivo = 'pagamento de outro sistema (não é evento)';\n    else if (!isValid) motivo = 'evento inválido';\n    else if (!shouldProcess) motivo = 'parcela > 1';\n    return [{ json: { skip: true, motivo } }];\n  }\n\n  return [{ json: {\n    skip: false,\n    inscricaoId,\n    asaasPaymentId: d.payment.id,\n    amount: d.payment.value,\n    billingType: d.payment.billingType,\n  } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1568,
        1984
      ],
