    {
      "parameters": {
        "jsCode": "const inscricao = $('Notif: Buscar Inscricao').first().json;\n\n  let d = (inscricao.telefone || '').toString().replace(/\\D/g, '');\n  if (d.startsWith('55') && d.length > 11) d = d.substring(2);\n\n  let ddd, num;\n  if (d.length <= 9) { ddd = '84'; num = d; }\n  else { ddd = d.substring(0, 2); num = d.substring(2); }\n\n  // Garante \"num\" sem o 9 do começo (8 dígitos)\n  const numSemNove = (num.length === 9 && num.startsWith('9')) ? num.substring(1) : num;\n\n  return [{ json: {\n    raw: inscricao.telefone,\n    phoneSemNove: `55${ddd}${numSemNove}`,\n    phoneComNove: `55${ddd}9${numSemNove}`,\n    chatIdSemNove: `55${ddd}${numSemNove}@c.us`,\n    chatIdComNove: `55${ddd}9${numSemNove}@c.us`,\n  }}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -560,
        2080
      ],
      "id": "7de45f84-25d8-450c-9a81-99b4b5574c5d",
      "name": "Notif: Formatar Telefone"
    },
    {
      "parameters": {},
