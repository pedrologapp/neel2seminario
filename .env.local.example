# ============================================================
# NEEL — Núcleo Espírita Esperança de Luz
# Copie este arquivo para .env.local e preencha com os valores REAIS.
# .env.local nunca vai pro Git. NÃO reaproveite segredos de outros projetos.
# ============================================================

# ---------- Supabase (projeto NOVO do NEEL) ----------
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------- n8n (workflows NOVOS do NEEL) ----------
# Webhook de inscrições → cria cobrança no Asaas
N8N_WEBHOOK_URL=https://webhook.example.com/webhook/eventos
# Webhook de notificação (Asaas confirma + dispara QR/WhatsApp; usado também em vendas em dinheiro)
N8N_NOTIFICACAO_URL=https://webhook.example.com/webhook/eventospagamentos
# Webhook de reenvio de QR codes (acionado pelo admin)
N8N_REENVIO_QR_URL=https://webhook.example.com/webhook/reenvio-qr
# Webhook de cobrança avulsa (cria link Asaas + envia no WhatsApp)
N8N_COBRANCA_AVULSA_URL=https://webhook.example.com/webhook/cobrancaavulsa

# Segredo compartilhado pro callback /api/inscricoes/confirmar (GERE UM NOVO)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_CONFIRM_SECRET=mude-isto-por-um-secret-aleatorio

# ---------- Anthropic (extração de avisos com IA — Claude) ----------
# Crie em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------- Senhas de acesso ----------
# Senha para ações sensíveis no admin (editar/excluir/duplicar evento) e portaria.
# Se não definida, usa um padrão fraco no código — DEFINA uma senha forte.
ADMIN_ACTION_PASSWORD=troque-esta-senha

# ---------- URL base ----------
# Domínio único (admin fica em /admin, portaria em /portaria — sem subdomínios).
# Em produção use a URL do projeto na Vercel, ex.: https://neel2seminario.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
